<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/genius1"
    android:gravity="center"
    android:orientation="horizontal">

    <Button
        android:id="@+id/voltar"
        android:layout_width="70dp"
        android:layout_height="51dp"
        android:backgroundTint="#2196F3"
        android:gravity="top"
        android:layout_marginTop="16dp"
        android:layout_marginStart="10dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:icon="?attr/homeAsUpIndicator" />

    <TextView
        android:id="@+id/txtConfigTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:layout_marginStart="10dp"
        android:text="Configuraçes"
        android:textColor="@color/white"
        android:textSize="34sp"
        android:textStyle="bold"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toEndOf="@id/voltar"/>

    <LinearLayout
        android:layout_width="417dp"
        android:layout_height="296dp"
        android:layout_marginStart="152dp"
        android:layout_marginTop="70dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Perfil"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Button
            android:id="@+id/perfiljogador"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Editar perfil" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Detalhes"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/switchDifficulty"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Modo difícil"
            android:textColor="@color/white" />


        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Visualizaçao"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="20dp"
            android:text="Sonoro"
            android:textColor="@color/white"
            android:textStyle="bold" />

        <Switch
            android:id="@+id/switchSound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Msica ligada"
            android:textColor="@color/white" />

        <Switch
            android:id="@+id/switchSound2"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:checked="true"
            android:text="Efeitos sonoros ligados"
            android:textColor="@color/white" />

        <Button
            android:id="@+id/resetConfig"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Restaurar configuraçoes padrao" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>